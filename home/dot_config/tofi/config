# Fonts
font = monospace
font-size = 10
hint-font = true

# Theme
text-color = #d8ded3
background-color = #4c5844

prompt-background-padding = 0
prompt-background-corner-radius = 0

input-background-padding = 0
input-background-corner-radius = 0

default-result-background-padding = 0
default-result-background-corner-radius = 0

selection-color = #d8ded3
selection-background = #5a6a60
selection-background-padding = 4
selection-background-corner-radius = 0

selection-match-color = #FFFFFF

text-cursor-style = bar

# Text layout
prompt-text = "run: "
prompt-padding = 0
num-results = 20
result-spacing = 12
horizontal = true
min-input-width = 120

# Window theming
width = 100%
height = 16
outline-width = 0
outline-color = #00000000
border-width = 0
border-color = #00000000
corner-radius = 0
padding-top = 0
padding-bottom = 0
padding-left = 0
padding-right = 0

clip-to-padding = false
scale = false

# Window positioning
output = ""
anchor = top
exclusive-zone = -1

margin-top = 0
margin-bottom = 0
margin-left = 0
margin-right = 0

# Behaviour
hide-cursor = false
text-cursor = false
history = true
require-match = true
auto-accept-single = false
hide-input = false
drun-launch = false
late-keyboard-init = false
multi-instance = false
ascii-input = false
