# ~/.bashrc
# run whenever bash is invoked

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# cow fortune
COWF=/tmp/cowfort
getfort() {
  fortune -s | $(test $(($RANDOM % 2)) -eq 1 && echo cowthink || echo cowthink) | lolcat -f
}
test -f $COWF && cat $COWF || getfort
( getfort > $COWF & )

# bash settings
bind -s 'set completion-ignore-case on'
shopt -s histappend
shopt -s no_empty_cmd_completion
shopt -s dirspell
shopt -s dotglob
shopt -s direxpand

# settings files
. ~/.aliases
. ~/.environment
. ~/.colours
