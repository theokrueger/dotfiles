# chezmoi.yaml
# this file was generated by chezmoi

# automatic configuration detection
{{- $chassisType := "desktop" }}
{{- $primaryMonWidth  := 1920 }}
{{- $primaryMonHeight := 1080 }}
{{- $windowManager := "" }}
{{- $kbLayout := "qwerty" }}

# macos
{{- if eq .chezmoi.os "darwin" }}
  # general macos config
  {{- $windowManager = "macos" }}
  # laptop or desktop?
  {{- if contains "MacBook" (output "sysctl" "-n" "hw.model") }}
    {{- $chassisType = "laptop" }}
  {{- else }}
    {{- $chassisType = "desktop" }}
  {{- end }}

# linux
{{- else if eq .chezmoi.os "linux" }}
   # general linux config
  {{- $windowManager = "sway" }}

  # systemd
  {{- if stat "/usr/bin/hostnamectl" }}
    # laptop or desktop?
    {{- $chassisType = (output "hostnamectl" "--json=short" | mustFromJson).Chassis }}

  # OpenRC / other
  {{- else }}
    # laptop or desktop?
    {{- if stat "/sys/class/power_supply/BAT0/present" }}
      {{- $chassisType = "laptop" }}
    {{- else }}
      {{- $chassisType = "desktop" }}      
    {{- end }}

    # hostname-based configuration
    {{- if eq .chezmoi.hostname "thonkpad" }}
      {{- $primaryMonWidth  = 1280 }}
      {{- $primaryMonHeight = 800 }}
      {{- $kbLayout = "qwerty" }}

    {{- else if eq .chezmoi.hostname "linsuslap" }}
      {{- $primaryMonWidth  = 1920 }}
      {{- $primaryMonHeight = 1080 }}
      {{- $kbLayout = "qwerty" }}

    {{- else if eq .chezmoi.hostname "gen2desk" }}
      {{- $primaryMonWidth  = 1920 }}
      {{- $primaryMonHeight = 1080 }}

    {{- end }}
  {{- end }}

# windows
{{- else if eq .chezmoi.os "windows" }}
  # general windows config
  {{- $windowManager = "windows" }}
  # laptop or desktop?
  {{- $chassisType = (output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "if ((Get-CimInstance -Class Win32_Battery | Measure-Object).Count -gt 0) { Write-Output 'laptop' } else { Write-Output 'desktop' }") | trim }}
{{- end }}

# directory of the dotfiles repo
sourceDir: ~/backups/code/theokrueger/dotfiles
edit.command: emacs -nw
encryption: "gpg"
gpg:
  symmetric: true

data:
  music_directory: ~/backups/mosic
  bar_height: 20
  font:
    size: 10
    family: monospace
  colours:
    bg: "#222222"
    fg: "#ff66cc"
    text: "#eee8d5"
    text_unfocused: "#93a1a1"
    text_focused: "#333333"
    border: "#657b83"
    highlight: "#7c81d4"

  # automatically set vars
  window_manager: {{ $windowManager }}
  chassis: {{ $chassisType }}
  primary_monitor_width: {{ $primaryMonWidth }}
  primary_monitor_height: {{ $primaryMonHeight }}
  keyboard_layout: {{ $kbLayout }}
