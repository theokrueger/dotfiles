# chezmoi.yaml
# this file was generated by chezmoi

# automatic configuration detection:
{{- $chassisType := "desktop" }}
{{- $primaryMonWidth  := 1920 }}
{{- $primaryMonHeight := 1080 }}

{{- $windowManager := "" }}

{{- $kbLayout := "qwerty" }}

{{- $lockscreen := "default.png" }}
{{- $staticBG := "default.png" }}
{{- $animatedBGEnabled := false }}
{{- $animatedBGFolder := "" }}
{{- $animatedBGDelay := 360 }}
{{- $animatedBGOverlay := "" }}

{{- $fgColour := "#ff66cc" }}
{{- $bgColour := "#222222" }}
{{- $fgLightColour := "#ff00ff" }}
{{- $fgDarkColour := "#d1c7cb" }}

{{- if eq .chezmoi.os "darwin" }}
  # this is macos
  {{- $windowManager = "macos" }}
  {{- if contains "MacBook" (output "sysctl" "-n" "hw.model") }}
    # this is laptop
    {{- $chassisType = "laptop" }}
  {{- else }}
    # this is desktop
    {{- $chassisType = "desktop" }}
  {{- end }}

{{- else if eq .chezmoi.os "linux" }}
  # this is linux
  {{- $windowManager = "sway" }}

  {{- if stat "/usr/bin/hostnamectl" }}
    # this is systemd
    {{- $chassisType = (output "hostnamectl" "--json=short" | mustFromJson).Chassis }}

  {{- else }}
    # this is openrc
    {{- if stat "/sys/class/power_supply/BAT0/present" }}
      # this is laptop
      {{- $chassisType = "laptop" }}
    {{- else }}
      # this is desktop
      {{- $chassisType = "desktop" }}
    {{- end }}

    {{- if eq .chezmoi.hostname "thonkpad" }}
      # this is thonkpad
      {{- $primaryMonWidth  = 1920 }}
      {{- $primaryMonHeight = 1080 }}
      {{- $kbLayout = "colemak_dh" }}
      {{- $lockscreen = "pneguin/1920x1080.png" }}
      {{- $staticBG = "hostname/pink/thonkpad_1920x1080.png" }}
      {{- $animatedBGEnabled = true }}
      {{- $animatedBGFolder = "gentoo-penguin" }}

    {{- else if eq .chezmoi.hostname "linsuslap" }}
      # this is linsuslap
      {{- $primaryMonWidth  = 1920 }}
      {{- $primaryMonHeight = 1080 }}
      {{- $kbLayout = "colemak_dh" }}
      {{- $lockscreen = "pneguin/1920x1080.png" }}
      {{- $staticBG = "hostname/pink/linsuslap_1920x1080.png" }}
      {{- $animatedBGEnabled = true }}
      {{- $animatedBGFolder = "gentoo-penguin" }}

    {{- else if eq .chezmoi.hostname "gen2desk" }}
      # this is gen2desk
      {{- $primaryMonWidth  = 1920 }}
      {{- $primaryMonHeight = 1080 }}
      {{- $kbLayout = "qwerty" }}
      {{- $lockscreen = "pneguin/1920x1080.png" }}
      {{- $staticBG = "hostname/pink/gen2desk_1920x1080.png" }}

    {{- else if eq .chezmoi.hostname "crapbookair" }}
      # this is crapbookair
      {{- $primaryMonWidth  = 2560 }}
      {{- $primaryMonHeight = 1600 }}
      {{- $kbLayout = "colemak_dh" }}
      {{- $lockscreen = "nostars.png" }}
      {{- $staticBG = "glt/stars.png" }}
      {{- $bgColour = "#000000" }}
      {{- $fgColour = "#ffffff" }}
      {{- $fgLightColour = "#ffffff" }}
      {{- $fgDarkColour = "#e0e0e0" }}
      # overriding to laptop
      {{- $chassisType = "laptop" }}
    {{- else }}
      # this has no configuration for given hostname
    {{- end }}
  {{- end }}

{{- else if eq .chezmoi.os "windows" }}
  # this is windows
  {{- $windowManager = "windows" }}
  {{- $chassisType = (output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "if ((Get-CimInstance -Class Win32_Battery | Measure-Object).Count -gt 0) { Write-Output 'laptop' } else { Write-Output 'desktop' }") | trim }}
{{- end }}

# directory of the dotfiles repo
sourceDir: ~/backups/dotfiles
edit.command: emacs -nw
encryption: "gpg"
gpg:
  symmetric: true

data:
  music_directory: ~/backups/mosic
  bar_height: 20
  font:
    size: 10
    family: monospace
  colours:
    bg: "{{ $bgColour }}"
    fg: "{{ $fgColour }}"
    fg_light: "{{ $fgLightColour }}"
    fg_dark: "{{ $fgDarkColour }}"
    text: "#eee8d5"
    text_unfocused: "#93a1a1"
    text_focused: "#333333"
    border: "#657b83"
    highlight: "#7c81d4"

  # automatically set vars
  window_manager: {{ $windowManager }}
  chassis: {{ $chassisType }}
  primary_monitor_width: {{ $primaryMonWidth }}
  primary_monitor_height: {{ $primaryMonHeight }}
  keyboard_layout: {{ $kbLayout }}

  lockscreen: ~/.local/share/assets/lockscreens/{{- $lockscreen }}
  static_background: ~/.local/share/assets/wallpapers/{{- $staticBG }}
  animated_background:
    enabled: {{ $animatedBGEnabled }}
    folder: ~/.local/share/assets/wallpapers/{{- $animatedBGFolder -}}/
    delay: {{ $animatedBGDelay }}
    overlay: ~/.local/share/assets/wallpapers/{{- $animatedBGOverlay }}
