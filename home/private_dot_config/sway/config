# root sway config
# Read `man 5 sway` for a complete reference.
include ./environment
include ./displays
include ./keybinds
include ./input
include ./style
include ./bar

# startup apps
exec_always autotiling
exec mako
exec pipewire
exec pipewire-pulse
exec wireplumber
exec otd

exec ~/.config/sway/scripts/xdg-desktop-portal.sh
exec_always ~/.config/sway/scripts/window-title-as-workspace.sh
exec swayidle -w timeout 300 '~/.config/sway/scripts/lock.sh' timeout 360 'swaymsg "output * dpms off"' timeout 420 'loginctl suspend' resume 'swaymsg "output * dpms on"' before-sleep '~/.config/sway/scripts/lock.sh'
