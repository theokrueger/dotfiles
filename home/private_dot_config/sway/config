# root sway config
# Read `man 5 sway` for a complete reference.
include ./environment
include ./displays
include ./keybinds
include ./input
include ./style
include ./bar

# startup apps
exec_always autotiling
exec mako
exec pipewire
exec pipewire-pulse
exec otd
exec ~/.config/sway/scripts/xdg-desktop-portal.sh
exec_always ~/.config/sway/scripts/window-title-as-workspace.sh
