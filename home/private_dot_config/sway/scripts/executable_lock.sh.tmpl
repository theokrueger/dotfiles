#!/bin/sh
echo 'Locking screen'
swaylock \
    --daemonize \
    --ignore-empty-password \
    --hide-keyboard-layout \
    --disable-caps-lock-text \
    --color {{ "" }}{{- .colours.bg | replaceAllRegex "#" "" }} \
    --font monospace \
    --font-size 24 \
    --show-failed-attempts \
    --scaling stretch \
    --image "{{- .lockscreen | replaceAllRegex "~" "$$HOME" }}" \
    --indicator-x-position 100 \
    --indicator-y-position $(( {{- .primary_monitor_height }} - 50)) \
    --text-color {{ "" }}{{- .colours.text | replaceAllRegex "#" "" }} \
    --bs-hl-color 00000000 \
    --caps-lock-bs-hl-color 00000000 \
    --caps-lock-key-hl-color 00000000 \
    --inside-color 00000000 \
    --inside-clear-color 00000000 \
    --inside-caps-lock-color 00000000 \
    --inside-ver-color 00000000 \
    --inside-wrong-color 00000000 \
    --key-hl-color 00000000 \
    --layout-bg-color 00000000 \
    --layout-text-color {{ "" }}{{- .colours.text | replaceAllRegex "#" "" }} \
    --line-color 00000000 \
    --line-clear-color 00000000 \
    --line-caps-lock-color 00000000 \
    --line-ver-color 00000000 \
    --line-wrong-color 00000000 \
    --ring-color 00000000 \
    --ring-clear-color 00000000 \
    --ring-caps-lock-color 00000000 \
    --ring-ver-color 00000000 \
    --ring-wrong-color 00000000 \
    --separator-color 00000000 \
    --text-clear-color {{ "" }}{{- .colours.text | replaceAllRegex "#" "" }} \
    --text-caps-lock-color {{ "" }}{{- .colours.text | replaceAllRegex "#" "" }} \
    --text-ver-color {{ "" }}{{- .colours.text | replaceAllRegex "#" "" }} \
    --text-wrong-color {{ "" }}{{- .colours.text | replaceAllRegex "#" "" }}

