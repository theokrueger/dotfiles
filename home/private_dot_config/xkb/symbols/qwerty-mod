default partial alphanumeric_keys
xkb_symbols "unmodified" {
        include "us(basic)"

        name[Group1] = "qwerty";
};

partial alphanumeric_keys
xkb_symbols "basic" {
        include "us(basic)"
        include "qwerty-mod(swap-caps)"

        name[Group1] = "qwerty modified";
};

partial alphanumeric_keys
xkb_symbols "colemak_dh" {
        include "us(colemak_dh)"
        include "qwerty-mod(swap-caps)"

        name[Group1] = "qwerty to colemak";
};

partial alphanumeric_keys
xkb_symbols "workman" {
        include "workman"
        include "qwerty-mod(swap-caps)"

        name[Group1] = "qwerty to workman";
};

partial alphanumeric_keys
xkb_symbols "swap-caps" {
        name[Group1] = "special keys swapped";

        // unbind lgui, bind caps to lgui, and prsc to caps
        replace key <CAPS> {[ Super_L ]};
        replace key <LWIN> {[ Print ]};
        replace key <PRSC> {[ Caps_Lock ]};
};

partial alphanumeric_keys
xkb_symbols "colemak_dh_mac" {
        include "us(colemak_dh)"

        name[Group1] = "qwerty to colemak with option<->command swap";

        replace key <CAPS> {[ Super_L ]};
        replace key <LWIN> {[ Alt_L ]};
        replace key <LALT> {[ Print ]};
        replace key <PRSC> {[ Caps_Lock ]};
};
