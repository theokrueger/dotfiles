{
	"layer": "top",
	"position": "top",
	"height": 20,


	"modules-left": ["hyprland/workspaces", "hyprland/window"],
	"modules-center": [],
	"modules-right": ["custom/xsetroot", "tray"],


	"hyprland/workspaces": {
		"disable-scroll": true,
		"format": "{name}",
	},

	"custom/xsetroot": {
		"interval": 4,
		"exec": "while date; do sleep 1; done",
		"format": "{}",
	},

	"tray": {
                "icon-size": 16,
		"spacing": 0,
	},
}
